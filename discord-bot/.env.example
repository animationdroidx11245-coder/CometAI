# Rename this file to .env and fill in your values (for local testing only).
# On Discloud, set these as environment variables in discloud.config or the Discloud panel instead.

DISCORD_TOKEN=your-bot-token-here
CLIENT_ID=your-application-client-id-here
# Optional: set a GUILD_ID during development to register commands instantly to one server.
# Leave blank/remove to register commands globally (takes up to ~1 hour to propagate).
GUILD_ID=
